{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_popup": "popup.html",
      "default_title": "Temp Mail PW"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   } ],
   "description": "Temp Mail PW offers a temporary, secure, anonymous, and free disposable email address to keep your real mailbox clean and secure.",
   "host_permissions": [ "https://tempmail.pw/*", "http://*/*", "https://*/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Temp Mail PW - Temporary Email Generator",
   "permissions": [ "storage", "activeTab", "tabs", "clipboardWrite", "notifications" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.0.6",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "icons/*", "qrcode.min.js", "font-awesome.min.css", "webfonts/*", "autofill-icon.png" ]
   } ]
}
